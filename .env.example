# Tina Cloud credentials — get these from https://app.tina.io after creating a project.
# Public on purpose: this id identifies the project, not who's editing.
PUBLIC_TINA_CLIENT_ID=your-client-id-here

# Read-only token for the Tina build to fetch schema. Keep secret in production.
TINA_TOKEN=your-read-only-token-here

# Optional: which branch Tina commits edits to. Defaults to "main".
# GITHUB_BRANCH=main
