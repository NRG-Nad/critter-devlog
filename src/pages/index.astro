---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TAGLINE } from '../consts';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout>
  <p class="tagline">{SITE_TAGLINE}</p>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a class="post-card" href={`${base}/posts/${post.slug}/`}>
          <div class="post-card-meta">
            <FormattedDate date={post.data.pubDate} />
            {post.data.tags.length > 0 && <span>&middot;</span>}
            {post.data.tags.slice(0, 3).map((t) => <span class="tag-pill">{t}</span>)}
          </div>
          <h2 class="post-card-title">{post.data.title}</h2>
          <p class="post-card-desc">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
